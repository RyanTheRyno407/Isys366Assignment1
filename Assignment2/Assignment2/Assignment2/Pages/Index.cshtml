@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class= "border border-primary mt-2 pt-2">
    <a asp-page="Privacy" asp-rout-variable="@Model.PersonModel.Name" asp-rout-variable="@Model.PersonModel.Age">Happy Birthday</a>
</div>

<div class="border border-primary mt-2 pt-2">
    <Label>GET</label>
        <form method="get" asp-page="Privacy" class="mt-2 pt-2">
            <label asp-for="PersonModel.Name">Name:</label>
            <input type="text" name="PersonModel.Name"/>
            <label asp-for="PersonModel.Age"> Age:</label>
            <input type="number" name="PersonModel.Age"/>
            <input type="submit" value="Submit!"/>
        </form>
</div>

<div class="border border-primary mt-2 pt-2">
    <Label>POST</label>
        <form method="post" asp-page="Privacy" class="mt-2 pt-2">
            <label asp-for="PersonModel.Name">Name:</label>
            <input type="text" name="PersonModel.Name"/>
            <label asp-for="PersonModel.Age"> Age:</label>
            <input type="number" name="PersonModel.Age"/>
            <input type="submit" value="Submit!"/>
        </form>
</div>

            <div class="border border-primary mt-2 pt-2">
    <Label>POSTBACK</label>
        <form method="post" asp-page="Index" class="mt-2 pt-2">
            <label asp-for="PersonModel.Name">Name:</label>
            <input type="text" name="PersonModel.Name"/>
            <label asp-for="PersonModel.Age"> Age:</label>
            <input type="number" name="PersonModel.Age"/>
            <input type="submit" value="Submit!"/>
        </form>
</div>